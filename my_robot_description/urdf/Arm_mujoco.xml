<mujoco model="ur3">
  <default>
    <default class="robot">
      <default class="motor">
        <joint damping="10" armature="0.1" />   <!-- 关节基本阻尼 -->
        <position ctrlrange="-100 100" kp="800" kv="50" forcerange="-100 100" />
        <!-- ctrlrange: 控制信号范围（通常对应力矩或位置，取决于控制类型）
           kp: 位置误差比例系数
           kv: 速度阻尼系数
           加上 forcerange 限制最大力矩，防止过冲 -->
      </default>
      <default class="visual">
        <geom material="visualgeom" contype="0" conaffinity="0" group="2" />
      </default>
      <default class="collision">
        <geom material="collision_material" condim="3" contype="0" conaffinity="1" priority="1" group="1" solref="0.005 1" solimp="0.99 0.999 1e-05" friction="1 0.01 0.01" />
      </default>
    </default>
  </default>

  <compiler angle="radian" />

  <asset>
    <!-- 天空盒背景 -->
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512"
      height="512" />
    <!-- 方格地板纹理 -->
    <texture name="texplane" type="2d" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 0.15 0.2"
      width="512" height="512" mark="cross" markrgb=".8 .8 .8" />
    <!-- 地板材质 -->
    <material name="matplane" reflectance="0.3" texture="texplane" texrepeat="1 1" texuniform="true" />
    <material name="base_link_white" rgba="1 1 1 1" />
    <material name="link1_light_grey" rgba="0.8 0.8 0.8 1" />
    <material name="link2_light_blue" rgba="0.5 0.7 1 1" />
    <material name="link3_light_green" rgba="0.5 1 0.7 1" />
    <material name="default_material" rgba="0.7 0.7 0.7 1" />
    <material name="collision_material" rgba="1.0 0.28 0.1 0.9" />
    <mesh name="base_link.obj" file="../meshes/base_link.obj" />
    <mesh name="link1.obj" file="../meshes/link1.obj" />
    <mesh name="link2.obj" file="../meshes/link2.obj" />
    <mesh name="link3.obj" file="../meshes/link3.obj" />
    <mesh name="gripper.obj" file="../meshes/gripper.obj" />
  </asset>

  <worldbody>
    <!-- 全局光照 -->
    <light directional="true" diffuse=".8 .8 .8" specular=".2 .2 .2" pos="0 0 5" dir="0 0 -1" />
    <!-- 添加无尽的物理地板平面 -->
    <geom name="floor" type="plane" size="0 0 1" material="matplane" condim="3" />

    <body name="base_link" pos="0.00000000 0.00000000 0.00000000" quat="1 0 0 0" childclass="robot">
      <geom name="base_link_collision_0" pos="-0.125 0.125 0.425" quat="1.0 0.0 0.0 0.0" type="box" size="0.0725 0.0725 0.415" class="collision" />
      <geom name="base_link_collision_1" pos="-0.125 0.125 0.005" quat="1.0 0.0 0.0 0.0" type="box" size="0.125 0.125 0.005" class="collision" />
      <geom name="base_link_visual" pos="0 0 0" quat="0.7071054825112363 0.7071080798594735 0.0 0.0" material="base_link_white" type="mesh" mesh="base_link.obj" class="visual" />
      <body name="link1" pos="-0.18 0.183 0.5841" quat="-0.500003673194984 0.4999963267847773 -0.5000018365958054 -0.4999981633907021" gravcomp="1">
        <joint name="joint1" type="slide" ref="0.0" class="motor" range="0 0.41" axis="1 0 0"
          damping="100" armature="1" />
        <inertial pos="0.028429 -0.10525 -0.058001" quat="0.01967413563049977 0.019651861197668128 -0.7068373938566186 -0.7068292802258859" mass="1.0689" diaginertia="0.0042871312 0.0037421 0.0011385688" />
        <geom name="link1_collision" pos="0.02575 -0.1005 -0.058" quat="0.4999981633974483 0.49999999999662686 0.5000018366025516 0.49999999999662686" type="box" size="0.1005 0.058 0.02575" class="collision" />
        <geom name="link1_visual" pos="0 0 0" quat="1.0 0.0 0.0 0.0" material="link1_light_grey" type="mesh" mesh="link1.obj" class="visual" />
        <body name="link2" pos="0.048996 -0.153 -0.058" quat="0.5330814320133039 -0.46456686007923853 0.5330848449120267 -0.4645668600792385" gravcomp="1">
          <joint name="joint2" type="hinge" ref="0.0" class="motor" range="-1.571 1.571"
            axis="0 0 -1" />
          <inertial pos="0.14475 -3.0463E-07 0.041307" quat="-0.7060863695927564 -0.006120118491469557 -0.7080728260558069 0.006120116527857341" mass="2.5831" diaginertia="0.0278951911 0.026394 0.0036790089" />
          <geom name="link2_collision" pos="0.18 0 0.03925" quat="1.0 0.0 0.0 0.0" type="box" size="0.2155 0.053 0.035" class="collision" />
          <geom name="link2_visual" pos="0 0 0" quat="1.0 0.0 0.0 0.0" material="link2_light_blue" type="mesh" mesh="link2.obj" class="visual" />
          <body name="link3" pos="0.325 0 0.077501" quat="0.07632203524029463 0.0 0.0 0.9970832196646272" gravcomp="1">
            <joint name="joint3" type="hinge" ref="0.0" class="motor" range="-2.862 2.862" axis="0 0 -1" />
            <inertial pos="-0.1088 -0.002117 0.025856" quat="0.04722380799708451 0.6974214421872765 0.04706415529887669 -0.7135532280227433" mass="1.2392" diaginertia="0.0104197785 0.0094998372 0.0012116843" />
            <geom name="link3_collision" pos="-0.145 0 0.0225" quat="1.0 0.0 0.0 0.0" type="box" size="0.1875 0.0525 0.0225" class="collision" />
            <geom name="link3_visual" pos="0 0 0" quat="1.0 0.0 0.0 0.0" material="link3_light_green" type="mesh" mesh="link3.obj" class="visual" />
            <body name="tool_link" pos="0.0 0.0 0.0" quat="1.0 0.0 0.0 0.0">
              <body name="gripper" pos="-0.275 0.0 0.055" quat="-2.5973434669646147e-06 2.597353007557415e-06 -0.7071080798547033 0.707105482506466" gravcomp="1">
                <joint name="joint_tool_gripper" type="hinge" ref="0.0" class="motor" range="-3.14 3.14" axis="0 1 0" />
                <inertial pos="-0.00983151017542139 0.0599333115427437 -0.00175977245523265" quat="0.49052611595707657 0.4913835391698289 0.5094157804067029 0.5083521512393036" mass="0.77675171638187" diaginertia="0.0040448627 0.0028051639 0.0018509871" />
                <geom name="gripper_collision" pos="0.091 -0.04875 0" quat="1.0 0.0 0.0 0.0" type="box" size="0.121 0.04875 0.07" class="collision" />
                <geom name="gripper_visual" pos="0.121 -0.1 0" quat="1.0 0.0 0.0 0.0" material="base_link_white" type="mesh" mesh="gripper.obj" class="visual" />
                <site name="ee_site" pos="0.2 0 0" size="0.02" />
              </body>
            </body>
          </body>
        </body>
      </body>
      <site name="base_link_site" pos="0 0 0" quat="1 0 0 0" />
      <camera name="front_camera" mode="track" fovy="90.0" quat="4.329780281177467e-17 4.329780281177466e-17 0.7071067811865475 0.7071067811865476" pos="0.0 2.0 0.5" />
      <camera name="side_camera" mode="track" fovy="90.0" quat="-0.5 -0.4999999999999999 0.5 0.5000000000000001" pos="-2.0 0.0 0.5" />
    </body>
  </worldbody>

  <actuator>
    <position name="joint1_ctrl" joint="joint1" class="motor" ctrlrange="0 0.41" />
    <position name="joint2_ctrl" joint="joint2" class="motor" ctrlrange="-1.571 1.571" />
    <position name="joint3_ctrl" joint="joint3" class="motor" ctrlrange="-2.862 2.862" />
    <position name="joint_tool_gripper_ctrl" joint="joint_tool_gripper" class="motor"
      ctrlrange="-3.14 3.14" />
  </actuator>

  <contact>
    <exclude body1="base_link" body2="link1" />
    <exclude body1="link1" body2="link2" />
    <exclude body1="link2" body2="link3" />
  </contact>

  <sensor>
    <framepos name="base_link_site_pos" objtype="site" objname="base_link_site" />
    <framequat name="base_link_site_quat" objtype="site" objname="base_link_site" />
    <framelinvel name="base_link_site_linvel" objtype="site" objname="base_link_site" />
    <frameangvel name="base_link_site_angvel" objtype="site" objname="base_link_site" />
    <velocimeter name="base_link_site_vel" site="base_link_site" />
  </sensor>
</mujoco>