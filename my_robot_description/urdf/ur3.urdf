<?xml version="1.0" encoding="utf-8"?>

<robot name="ur3">
    <mujoco>
        <compiler meshdir="../meshes/" balanceinertia="true" discardvisual="false" />
    </mujoco>
    <!-- 底座连杆 base_link - 单独配置颜色（白色） -->
    <link name="base_link">
        <inertial>
            <origin xyz="-0.13943 -0.12437 -0.34278" rpy="0 0 0" />
            <mass value="4.5671" />
            <inertia ixx="0.20051" ixy="-8.0396E-05" ixz="0.00036454" iyy="0.19652" iyz="-0.0014165"
                izz="0.026986" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0" />
            <geometry>
                <mesh filename="../meshes/base_link.obj" />
            </geometry>
            <!-- 单独写颜色：白色（rgba=1 1 1 1） -->
            <material name="base_link_white">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="-0.125 0.125 0.425" rpy="0 0 0" />
            <geometry>
                <box size="0.145 0.145 0.83" />
            </geometry>
        </collision>
        <collision>
            <origin xyz="-0.125 0.125 0.005" rpy="0 0 0" />
            <geometry>
                <box size="0.25 0.25 0.01" />
            </geometry>
        </collision>
    </link>
    <!-- 连杆 link1 - 单独配置颜色（浅灰色） -->
    <link name="link1">
        <inertial>
            <origin xyz="0.028429 -0.10525 -0.058001" rpy="0 0 0" />
            <mass value="1.0689" />
            <inertia ixx="0.0042774" ixy="0.00017477" ixz="-1.5776E-08" iyy="0.0011483"
                iyz="-2.8503E-08" izz="0.0037421" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="../meshes/link1.obj" />
            </geometry>
            <!-- 单独写颜色：浅灰色（rgba=0.8 0.8 0.8 1） -->
            <material name="link1_light_grey">
                <color rgba="0.8 0.8 0.8 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0.02575 -0.1005 -0.058" rpy="1.5708 0 1.5708" />
            <geometry>
                <box size="0.201 0.116 0.0515" />
            </geometry>
        </collision>
    </link>
    <!-- 连杆 link2 - 单独配置颜色（浅蓝色） -->
    <link name="link2">
        <inertial>
            <origin xyz="0.14475 -3.0463E-07 0.041307" rpy="0 0 0" />
            <mass value="2.5831" />
            <inertia ixx="0.0036792" ixy="4.4029E-08" ixz="6.8027E-05" iyy="0.026394"
                iyz="-3.6629E-08" izz="0.027895" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="../meshes/link2.obj" />
            </geometry>
            <!-- 单独写颜色：浅蓝色（rgba=0.5 0.7 1 1） -->
            <material name="link2_light_blue">
                <color rgba="0.5 0.7 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0.18 0 0.03925" rpy="0 0 0" />
            <geometry>
                <box size="0.431 0.106 0.07" />
            </geometry>
        </collision>
    </link>


    <!-- 连杆 link3 - 单独配置颜色（浅绿色） -->
    <link name="link3">
        <inertial>
            <origin xyz="-0.1088 -0.002117 0.025856" rpy="0 0 0" />
            <mass value="1.2392" />
            <inertia ixx="0.0012197" ixy="-0.00016376" ixz="0.00020961" iyy="0.0094966"
                iyz="5.3385E-06" izz="0.010415" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="../meshes/link3.obj" />
            </geometry>
            <!-- 单独写颜色：浅绿色（rgba=0.5 1 0.7 1） -->
            <material name="link3_light_green">
                <color rgba="0.5 1 0.7 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="-0.145 0 0.0225" rpy="0 0 0" />
            <geometry>
                <box size="0.375 0.105 0.045" />
            </geometry>
        </collision>
    </link>
    <link name="tool_link"/>

    <link
        name="gripper">
        <inertial>
            <origin
                xyz="-0.00983151017542139 0.0599333115427437 -0.00175977245523265"
                rpy="0 0 0" />
            <mass
                value="0.77675171638187" />
            <inertia
                ixx="0.00185381068085517"
                ixy="-7.86059690722816E-05"
                ixz="-1.82743897733095E-06"
                iyy="0.00404204258926908"
                iyz="-2.78591740390197E-07"
                izz="0.00280516037345738" />
        </inertial>
        <visual>
            <origin
                xyz="0.121 -0.1 0"
                rpy="0 0 0" />
            <geometry>
                <mesh
                    filename="../meshes/gripper.obj" />
            </geometry>
            <material
                name="">
                <color
                    rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin
                xyz="0.091 -0.04875 0"
                rpy="0 0 0" />
            <geometry>
                <box size="0.242 0.0975 0.140" />
            </geometry>
        </collision>
    </link>

    <!-- 移动关节 joint1（棱柱关节） -->
    <joint name="joint1" type="prismatic">
        <origin xyz="-0.18 0.183 0.5841" rpy="3.1416 1.5708 -1.5708" />
        <parent link="base_link" />
        <child link="link1" />
        <axis xyz="1 0 0" />
        <limit lower="-0.8" upper="0.8" effort="100" velocity="1" />
    </joint>
    <!-- 旋转关节 joint2（绕 z 轴负方向） -->
    <joint name="joint2" type="revolute">
        <origin xyz="0.048996 -0.153 -0.058" rpy="-1.5708 0.13714 -1.5708" />
        <parent link="link1" />
        <child link="link2" />
        <axis xyz="0 0 -1" />
        <limit lower="-3.14" upper="3.14" effort="100" velocity="1" />
    </joint>
    <!-- 旋转关节 joint3（绕 z 轴负方向） -->
    <joint name="joint3" type="revolute">
        <origin xyz="0.325 0 0.077501" rpy="0 0 2.9888" />
        <parent link="link2" />
        <child link="link3" />
        <axis xyz="0 0 -1" />
        <limit lower="-3.14" upper="3.14" effort="100" velocity="1" />
    </joint>
    <joint name="joint3_tool" type="fixed">
        <parent link="link3" />
        <child link="tool_link" />
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    </joint>
    
    <joint name="joint_tool_gripper" type="revolute">
        <origin xyz="-0.275 0.0 0.055" rpy="-1.5708 0.0 3.1416" />
        <parent link="tool_link" />
        <child link="gripper" />
        <axis xyz="0 1 0" />
       <limit lower="-3.14" upper="3.14" effort="100" velocity="1" />
    </joint>
    
<!-- 以下是mujoco的控制器相关配置 -->
    <!-- <mujoco>
    <actuator>
        <position name="act_joint1" joint="joint1" kp="1000" />
        <position name="act_joint2" joint="joint2" kp="500" />
        <position name="act_joint3" joint="joint3" kp="500" />
        <position name="act_joint_tool_gripper" joint="joint_tool_gripper" kp="100" />
        
        </actuator>
</mujoco> -->


</robot>